# LLM Configuration - Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Embedding Model
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Vector Database
VECTOR_DB_TYPE=chroma
CHROMA_DIR=./chroma_db_multilingual
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aaoifi_standards
QDRANT_VECTOR_SIZE=768
QDRANT_TIMEOUT_SECONDS=10

# Corpus Location - Using existing gemini-gem-prototype corpus
CORPUS_DIR=./gemini-gem-prototype/knowledge-base

# Document Storage
DOCUMENT_DB_TYPE=sqlite
SQLITE_DB_PATH=./data/documents.db

# Session Management
SESSION_STORE_TYPE=memory
SESSION_EXPIRY_MINUTES=30
SESSION_SECRET_KEY=your_session_secret_key_here
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT_SECONDS=2

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Rate Limiting
RATE_LIMIT_STORE_TYPE=memory
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_FREE=10
RATE_LIMIT_STANDARD=100
RATE_LIMIT_PREMIUM=1000

# Audit and Cache
AUDIT_DATABASE_URL=
DATABASE_URL=
CACHE_STORE_TYPE=memory
RESPONSE_CACHE_TTL_SECONDS=86400
RAG_EVAL_MODE=false
REQUIRE_DISCLAIMER_ACK=false

# Encryption
ENCRYPTION_MASTER_KEY=your_32_byte_encryption_key_here

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# AAOIFI Scraping
AAOIFI_BASE_URL=https://aaoifi.com
AAOIFI_STANDARDS_URL=https://aaoifi.com/accounting-standards-2/?lang=en

# API
API_HOST=0.0.0.0
API_PORT=8000
# Local development default only. Set explicit HTTPS origins for demo/release deployments.
CORS_ORIGINS=["*"]

# Optional integration test services
MUSHIR_TEST_REDIS_URL=
MUSHIR_TEST_DATABASE_URL=
MUSHIR_TEST_QDRANT_URL=
