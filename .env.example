# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Vector Database
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Document Storage
DOCUMENT_DB_TYPE=sqlite
SQLITE_DB_PATH=./data/documents.db

# Session Management
SESSION_EXPIRY_MINUTES=30
SESSION_SECRET_KEY=your_session_secret_key_here

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Rate Limiting
RATE_LIMIT_FREE=10
RATE_LIMIT_STANDARD=100
RATE_LIMIT_PREMIUM=1000

# Encryption
ENCRYPTION_MASTER_KEY=your_32_byte_encryption_key_here

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# AAOIFI Scraping
AAOIFI_BASE_URL=https://aaoifi.com
AAOIFI_STANDARDS_URL=https://aaoifi.com/accounting-standards-2/?lang=en

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]
