# LLM Configuration - Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Embedding Model
EMBED_MODEL=sentence-transformers/all-mpnet-base-v2

# Vector Database
CHROMA_DIR=./chroma_db

# Corpus Location - Using existing gemini-gem-prototype corpus
CORPUS_DIR=./gemini-gem-prototype/knowledge-base

# Document Storage
DOCUMENT_DB_TYPE=sqlite
SQLITE_DB_PATH=./data/documents.db

# Session Management
SESSION_EXPIRY_MINUTES=30
SESSION_SECRET_KEY=your_session_secret_key_here

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Rate Limiting
RATE_LIMIT_FREE=10
RATE_LIMIT_STANDARD=100
RATE_LIMIT_PREMIUM=1000

# Encryption
ENCRYPTION_MASTER_KEY=your_32_byte_encryption_key_here

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# AAOIFI Scraping
AAOIFI_BASE_URL=https://aaoifi.com
AAOIFI_STANDARDS_URL=https://aaoifi.com/accounting-standards-2/?lang=en

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]
